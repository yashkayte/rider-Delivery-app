<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtOrderId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Order #KH1024"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#212121" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW"
                app:chipCornerRadius="14dp"
                app:chipBackgroundColor="#E8F5E9"
                android:textColor="#2E7D32" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pickup"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#757575"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/txtPickup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pizza Hut, Andheri West"
            android:textSize="14sp"
            android:textColor="#212121"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Drop"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#757575"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/txtDrop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bandra East, Mumbai"
            android:textSize="14sp"
            android:textColor="#212121"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/txtMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Distance: 4.2 km • COD"
            android:textSize="12sp"
            android:textColor="#757575"
            android:layout_marginTop="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="14dp">

            <TextView
                android:id="@+id/txtEarning"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="₹75"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#6A1B9A" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAccept"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Accept"
                android:textColor="@android:color/white"
                android:backgroundTint="#2E7D32"
                app:cornerRadius="14dp" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>