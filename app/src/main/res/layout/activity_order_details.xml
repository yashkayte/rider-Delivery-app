<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/txtOrderId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Order #KH-0000"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#212121"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="#E0E0E0"/>

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pickup Location"
                    android:textStyle="bold"
                    android:textColor="#6A1B9A"
                    android:textSize="14sp"/>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/txtPickup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pickup address here"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="#E0E0E0"/>

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Drop Location"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:textSize="14sp"/>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/txtDrop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Drop address here"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Customer Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Customer Details"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#212121"/>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/txtCustomerName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Customer Name"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:layout_marginTop="10dp"/>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/txtCustomerPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="+91XXXXXXXXXX"
                    android:textColor="#757575"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCallCustomer"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Call Customer"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#2E7D32"
                    android:layout_marginTop="14dp"
                    app:cornerRadius="16dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Action Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartNavigation"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Start Navigation"
            android:textColor="@android:color/white"
            android:backgroundTint="#6A1B9A"
            android:layout_marginTop="18dp"
            app:cornerRadius="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickedUp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Mark Picked Up"
            android:textColor="@android:color/white"
            android:backgroundTint="#1565C0"
            android:layout_marginTop="12dp"
            app:cornerRadius="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelivered"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Mark Delivered"
            android:textColor="@android:color/white"
            android:backgroundTint="#D32F2F"
            android:layout_marginTop="12dp"
            app:cornerRadius="16dp"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>