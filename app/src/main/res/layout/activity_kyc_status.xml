<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KYC Verification"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#212121" />

                <TextView
                    android:id="@+id/txtKycStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status: Pending Verification"
                    android:textSize="14sp"
                    android:textColor="#6A1B9A"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Upload documents to start receiving orders faster."
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Document checklist -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Required Documents"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="10dp" />

                <TextView android:text="✅ Aadhaar Card" android:textSize="14sp" android:textColor="#424242"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <TextView android:text="✅ PAN Card" android:textSize="14sp" android:textColor="#424242"
                    android:layout_marginTop="6dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <TextView android:text="✅ Driving License" android:textSize="14sp" android:textColor="#424242"
                    android:layout_marginTop="6dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <TextView android:text="✅ Vehicle RC" android:textSize="14sp" android:textColor="#424242"
                    android:layout_marginTop="6dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <TextView android:text="✅ Insurance" android:textSize="14sp" android:textColor="#424242"
                    android:layout_marginTop="6dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUploadDocs"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Upload Documents"
            android:textColor="@android:color/white"
            android:backgroundTint="#6A1B9A"
            android:layout_marginTop="18dp"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSkipKyc"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Skip for now"
            android:textColor="#757575"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</ScrollView>